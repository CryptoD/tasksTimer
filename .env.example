# Copy to `.env` for local reference (optional).
# This repo does NOT auto-load `.env` for `gjs main.js` — export vars in your shell
# or use them only for Node/Playwright tooling commands.
#
# Never commit real secrets. All values below are placeholders.

# --- Deployment mode (fail-fast when production) ---
# When TASKTIMER_ENV or TASKMASTER_ENV=production, main.js exits unless all four
# secrets below are set (min 16 chars, not placeholder prefixes). Omit in dev.
# TASKTIMER_ENV=development
# TASKTIMER_SESSION_SECRET=replace-with-long-random-session-secret
# TASKTIMER_JWT_SECRET=replace-with-long-random-jwt-secret
# TASKTIMER_CSRF_SECRET=replace-with-long-random-csrf-secret
# TASKTIMER_INTEGRATION_SECRET=replace-with-long-random-integration-secret

# --- Playwright browser shell (Node / CI tooling) ---
# Default: mocks on (omit or set to true). Real-backend job uses false.
REACT_APP_USE_MOCKS=true

# Optional: base URL when running e2e/real-backend.spec.mjs with mocks disabled.
# E2E_BASE_URL=https://api.example.com

# --- API error diagnostics (GJS; dev-only) ---
# When 1, mapped user errors may append raw server details (see docs/api/errors.md).
TASKTIMER_API_DEV_ERRORS=0

# --- Standalone GTK app (debug / test helpers) ---
TASKTIMER_DEBUG_GTK_PACK=0
TASKTIMER_FORCE_INAPP_NOTIFICATIONS=0

# Test-only hook (used by tests/test15_atomic_json_save.js; do not set in normal use)
# TASKTIMER_TEST_FAIL_JSON_SAVE=0

# --- Standard desktop / packaging (usually set by the session, not copied from here) ---
# LANGUAGE=en_US.UTF-8
# APPDIR=/path/to/AppImage/mount
# DESKTOP_STARTUP_ID=
# XDG_CONFIG_HOME=$HOME/.config
