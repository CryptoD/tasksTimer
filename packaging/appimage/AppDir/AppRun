#!/bin/sh
# AppImage entry: set APPDIR, cwd, and launch the GJS standalone app.
# Runtime: system gjs + GTK (see ../APPDIR.md).

SELF=$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")
HERE=$(dirname "$SELF")
export APPDIR="$HERE"
cd "$HERE" || exit 1
exec gjs "$HERE/main.js" "$@"
