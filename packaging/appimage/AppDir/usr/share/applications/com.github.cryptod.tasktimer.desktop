[Desktop Entry]
Type=Application
Version=1.0
Name=taskTimer
GenericName=Task Timer
Comment=Run multiple named timers with alarms, tray integration, and optional notifications
Icon=com.github.cryptod.tasktimer
Exec=tasktimer %U
TryExec=gjs
Terminal=false
Categories=Utility;Clock;
Keywords=timer;alarm;clock;task;kitchen;pomodoro;reminder;countdown;GTK;GNOME;
StartupNotify=true
StartupWMClass=com.github.cryptod.tasktimer
SingleMainWindow=true
